{
  "format_version": "1.0.0",
  "id": "chromecast",
  "name": "Chromecast Now Playing",
  "version": "1.0.0",
  "type": "service",
  "description": "Show what's currently casting on any Chromecast on your network — works with YouTube Music, Spotify, Netflix, Plex and more",
  "author": "Calvin Team",
  "license": "MIT",
  "homepage": "https://github.com/calvin-dashboard/calvin-plugins",
  "repository": "https://github.com/calvin-dashboard/calvin-plugins",
  "keywords": ["service", "chromecast", "now-playing", "music", "cast"],
  "python_dependencies": ["pychromecast>=14.0"],
  "dependencies": {
    "python": ">=3.10",
    "calvin": ">=1.0.0"
  },
  "files": {
    "include": [
      "plugin.py",
      "plugin.json",
      "frontend/NowPlaying.vue"
    ],
    "exclude": [
      "*.md",
      "tests/**",
      "__pycache__/**"
    ]
  },
  "requirements": {
    "restart_required": true,
    "config_required": false
  }
}
