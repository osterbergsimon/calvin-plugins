{
  "format_version": "1.0.0",
  "protocol_version": 1,
  "id": "system_monitor",
  "name": "System Monitor",
  "version": "1.0.0",
  "type": "service",
  "description": "Live system metrics — CPU, memory, disk, temperature and network. Optimised for Raspberry Pi.",
  "author": "Calvin Team",
  "license": "MIT",
  "homepage": "https://github.com/calvin-dashboard/calvin-plugins",
  "repository": "https://github.com/calvin-dashboard/calvin-plugins",
  "keywords": [
    "service",
    "system",
    "monitor",
    "cpu",
    "memory",
    "raspberry-pi"
  ],
  "python_dependencies": [
    "psutil>=5.9"
  ],
  "dependencies": {
    "python": ">=3.10",
    "calvin": ">=1.0.0"
  },
  "files": {
    "include": [
      "plugin.py",
      "plugin.json",
      "frontend/SystemMonitor.vue",
      "frontend/SystemStatusbar.vue"
    ],
    "exclude": [
      "*.md",
      "tests/**",
      "__pycache__/**"
    ]
  },
  "requirements": {
    "restart_required": true,
    "config_required": false
  }
}
